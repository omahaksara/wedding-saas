<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Ken-Z Edition</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
:root{--bg:#121212;--fg:#D1D5DB;--accent:#C5A572}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--fg)}
.font-serif{font-family:'Instrument Serif',serif}
.grain{position:fixed;inset:-100%;width:300%;height:300%;background:url('https://upload.wikimedia.org/wikipedia/commons/7/76/1k_Grain_Noise.png');opacity:.04;animation:g 8s steps(10) infinite;pointer-events:none;z-index:99}
@keyframes g{0%,100%{transform:translate(0,0)}50%{transform:translate(-5%,10%)}}
.hero-img{filter:grayscale(1) contrast(1.1)}
</style>
</head>
<body>
<div class="grain"></div>
<div id="loader" class="fixed inset-0 z-[200] bg-[#121212] flex items-center justify-center"><p class="text-[10px] tracking-[.4em]">LOADING</p></div>

<!-- COVER -->
<div id="cover" class="fixed inset-0 z-50 bg-[#121212] flex items-center justify-center p-6">
  <div class="border border-zinc-800 p-8 text-center w-full max-w-xs">
    <p class="text-[10px] tracking-[.3em] opacity-50 mb-10">THE UNION OF</p>
    <h1 id="cover-names" class="font-serif text-6xl italic text-white mb-16"></h1>
    <p class="text-[11px] opacity-40">Untuk</p>
    <p id="cover-guest" class="text-lg mb-10 border-b border-zinc-800 pb-2"></p>
    <button id="open" class="border border-zinc-600 px-8 py-2 text-[11px] tracking-widest hover:bg-white hover:text-black transition">ENTER</button>
  </div>
</div>

<main id="app" class="max-w-md mx-auto opacity-0">
  <!-- HERO -->
  <section class="h-[85vh] relative flex items-center justify-center overflow-hidden">
    <img id="hero" class="hero-img absolute inset-0 w-full h-full object-cover opacity-60" src="">
    <div class="relative text-center">
      <h2 id="names" class="font-serif text-7xl text-white leading-none"></h2>
      <div class="w-16 h-px bg-white/20 mx-auto my-5"></div>
      <p id="date" class="text-[10px] tracking-[.4em]"></p>
    </div>
    <button id="musicBtn" class="hidden absolute bottom-6 right-6 w-10 h-10 rounded-full bg-white/10 backdrop-blur border border-white/20 flex items-center justify-center text-sm">♪</button>
  </section>

  <!-- QUOTE -->
  <section class="px-10 py-14 text-center">
    <p id="arab" class="font-serif text-xl leading-relaxed mb-4 opacity-80" dir="rtl"></p>
    <p id="quote" class="text-sm opacity-60 italic"></p>
    <p id="source" class="text-[10px] mt-2 opacity-40"></p>
  </section>

  <!-- COUPLE -->
  <section class="px-8 space-y-20">
    <div><img id="groom-img" class="w-full aspect-[4/5] object-cover grayscale border border-zinc-800 mb-4" src=""><h3 id="groom-name" class="font-serif text-4xl"></h3><p id="groom-parents" class="text-[10px] uppercase tracking-widest opacity-40 mt-1"></p></div>
    <div class="text-center font-serif text-3xl opacity-20 italic">&</div>
    <div class="text-right"><img id="bride-img" class="w-full aspect-[4/5] object-cover grayscale border border-zinc-800 mb-4" src=""><h3 id="bride-name" class="font-serif text-4xl"></h3><p id="bride-parents" class="text-[10px] uppercase tracking-widest opacity-40 mt-1"></p></div>
  </section>

  <!-- EVENTS -->
  <section class="px-8 py-16 mt-16 border-t border-zinc-900">
    <h3 class="font-serif text-2xl mb-8">Save The Date</h3>
    <div id="events" class="space-y-6"></div>
  </section>

  <!-- LOVE STORY -->
  <section id="story-sec" class="px-8 py-16 border-t border-zinc-900 hidden">
    <h3 class="font-serif text-2xl mb-8">Perjalanan</h3>
    <div id="story" class="space-y-8"></div>
  </section>

  <!-- GALLERY -->
  <section id="gal-sec" class="py-16 border-t border-zinc-900 hidden">
    <h3 class="font-serif text-2xl mb-8 px-8">Gallery</h3>
    <div id="gallery" class="grid grid-cols-2 gap-px bg-zinc-900"></div>
  </section>

  <!-- VIDEO -->
  <section id="vid-sec" class="px-8 py-16 border-t border-zinc-900 hidden">
    <h3 class="font-serif text-2xl mb-6">Video</h3>
    <div class="aspect-video bg-black"><iframe id="yt" class="w-full h-full" frameborder="0" allowfullscreen></iframe></div>
  </section>

  <!-- GIFT -->
  <section id="gift-sec" class="px-8 py-16 border-t border-zinc-900 hidden">
    <h3 class="font-serif text-2xl mb-8">Wedding Gift</h3>
    <div id="gifts" class="space-y-4"></div>
  </section>

  <!-- LOGISTICS -->
  <section id="log-sec" class="px-8 py-16 border-t border-zinc-900 text-sm opacity-70 hidden">
    <p id="dress"></p>
    <p id="note" class="mt-3"></p>
    <a id="rsvp" class="inline-block mt-6 border border-zinc-700 px-6 py-2 text-[11px] tracking-widest hover:bg-white hover:text-black transition">RSVP WHATSAPP</a>
  </section>

  <footer class="py-12 text-center border-t border-zinc-900">
    <p class="text-[10px] tracking-[.5em] opacity-30">OMAH AKSARA — 2026</p>
  </footer>
</main>

<audio id="audio" loop></audio>

<script>
const p = new URLSearchParams(location.search);
const slug = p.get('c');
const guest = p.get('to') || 'Tamu Undangan';
const base = `../../public/clients/${slug}/`;

fetch(base+'data.json').then(r=>r.json()).then(d=>{
  // theme
  if(d.settings?.themeColor) document.documentElement.style.setProperty('--accent', d.settings.themeColor);

  const g = d.couple.groom, b = d.couple.bride, names = `${g.nickname} & ${b.nickname}`;
  document.title = names;

  // cover
  coverNames.textContent = names; coverGuest.textContent = guest;
  // hero
  hero.src = base + d.gallery.heroImage; namesEl = document.getElementById('names'); namesEl.textContent = names;
  date.textContent = new Date(d.events[0].date).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'}).toUpperCase();

  // quote
  arab.textContent = d.quote.arab; quote.textContent = `"${d.quote.text}"`; source.textContent = d.quote.source;

  // couple
  document.getElementById('groom-img').src = base+g.image; groomName.textContent = g.name; groomParents.textContent = `Putra ${g.father} & ${g.mother}`;
  document.getElementById('bride-img').src = base+b.image; brideName.textContent = b.name; brideParents.textContent = `Putri ${b.father} & ${b.mother}`;

  // events
  const evWrap = document.getElementById('events');
  d.events.forEach(ev=>{
    const dt = new Date(ev.date).toLocaleDateString('id-ID',{weekday:'long',day:'numeric',month:'long'});
    evWrap.innerHTML += `<div class="border border-zinc-800 p-5"><h4 class="font-serif text-xl mb-1">${ev.title}</h4><p class="text-[11px] tracking-widest opacity-60">${dt} • ${ev.startTime}-${ev.endTime}</p><p class="text-xs mt-2 opacity-70">${ev.address}</p>${ev.googleMaps?`<a href="${ev.googleMaps}" target="_blank" class="text-[10px] underline opacity-50 mt-2 inline-block">MAPS</a>`:''}</div>`;
  });

  // story - FIX pakai date & description
  if(d.loveStory?.length){
    document.getElementById('story-sec').classList.remove('hidden');
    const s = document.getElementById('story');
    d.loveStory.forEach(it=> s.innerHTML += `<div><p class="text-[10px] tracking-[.3em] opacity-40">${it.date}</p><h4 class="font-serif text-xl mt-1">${it.title}</h4><p class="text-sm opacity-70 mt-1">${it.description}</p></div>`);
  }

  // gallery
  if(d.gallery.album?.length){
    document.getElementById('gal-sec').classList.remove('hidden');
    const gWrap = document.getElementById('gallery');
    d.gallery.album.forEach(img=> gWrap.innerHTML += `<img src="${base+img}" class="w-full aspect-square object-cover grayscale hover:grayscale-0 transition">`);
  }

  // video
  if(d.gallery.videoYoutubeId){
    document.getElementById('vid-sec').classList.remove('hidden');
    document.getElementById('yt').src = `https://www.youtube.com/embed/${d.gallery.videoYoutubeId}`;
  }

  // gift
  if(d.digitalGift?.length){
    document.getElementById('gift-sec').classList.remove('hidden');
    const gw = document.getElementById('gifts');
    d.digitalGift.forEach(gf=> gw.innerHTML += `<div class="border border-zinc-800 p-4 text-xs"><p class="opacity-50">${gf.provider}</p><p class="font-mono text-lg tracking-wider my-1">${gf.accountNumber}</p><p>a.n ${gf.accountHolder}</p>${gf.qrImage?`<img src="${base+gf.qrImage}" class="w-24 mt-2">`:''}</div>`);
  }

  // logistics
  if(d.logistics){
    document.getElementById('log-sec').classList.remove('hidden');
    dress.textContent = `Dresscode: ${d.logistics.dressCode}`;
    note.textContent = d.logistics.guestNote;
    rsvp.href = `https://wa.me/${d.logistics.rsvpWaNumber}?text=Halo, saya ${guest} konfirmasi hadir untuk ${names}`;
    if(d.logistics.music){
      const a = document.getElementById('audio'); a.src = base+d.logistics.music;
      musicBtn.classList.remove('hidden');
      let play=false; musicBtn.onclick=()=>{play? a.pause():a.play(); play=!play; musicBtn.textContent=play?'❚❚':'♪'};
    }
  }

  loader.style.display='none';
  open.onclick = ()=> gsap.to(cover,{opacity:0,duration:1,onComplete:()=>{cover.style.display='none'; gsap.to(app,{opacity:1,duration:1.5})}});
}).catch(e=>{loader.innerHTML='<p>ERROR</p>'; console.error(e)});
</script>
</body>
</html>
